# ── Base de datos ──────────────────────────────────────────────────────────────
# En producción usar la URL que proporciona Railway
DATABASE_URL=postgresql://epo_user:epo_pass@db:5432/reserva_epo

# ── Seguridad ──────────────────────────────────────────────────────────────────
# OBLIGATORIO: Genera un secreto fuerte con: openssl rand -hex 32
# NUNCA uses el valor de ejemplo en producción
JWT_SECRET=REEMPLAZA_CON_RESULTADO_DE__openssl_rand_-hex_32

# ── Servidor ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── CORS ───────────────────────────────────────────────────────────────────────
# En producción: URL exacta del frontend en Railway (sin barra final)
# Ej: CORS_ORIGIN=https://frontend-production-xxxx.up.railway.app
CORS_ORIGIN=http://localhost:3000

# ── Admin inicial ──────────────────────────────────────────────────────────────
# Contraseña temporal del primer admin — cambia INMEDIATAMENTE después del primer login
ADMIN_EMAIL=admin@epo.edu.mx
ADMIN_DEFAULT_PASS=CambiaEstePassword123!
